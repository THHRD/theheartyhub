<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="account_fiscal_sequence_form" model="ir.ui.view">
        <field name="name">account.fiscal.sequence.form</field>
        <field name="model">account.fiscal.sequence</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_queue" string="Queue" type="object" invisible="state != 'draft' or not can_be_queue"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('cancelled', 'draft')"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,depleted"/>
                </header>
                <sheet>
                    <field name="can_be_queue" invisible="True"/>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="action_view_sequence" icon="fa-arrow-right" type="object" groups="base.group_system" invisible="not sequence_id">
                            <span class="o_stat_text">Sequence</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Eg : 8001695033"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="fiscal_type_id" widget="selection" domain="[('assigned_sequence', '=', True)]" />
                            <field name="sequence_start"/>
                            <field name="sequence_end"/>
                            <field name="expiration_date"/>
                        </group>
                        <group>
                            <field name="warning_gap" invisible="True"/>
                            <label string="Remaining warning" for="remaining_percentage"/>
                            <div class="o_row" name="remaining_percentage">
                                <field name="remaining_percentage"/>
                                <span>%</span>
                            </div>
                            <field name="number_next_actual" groups="base.group_no_one"/>
                            <field name="sequence_remaining" invisible="state in ('draft', 'cancelled')"/>
                            <field name="next_fiscal_number" invisible="state in ('draft', 'cancelled', 'depleted')" />
                            <field name="type" invisible="True"/>
                            <field name="sequence_id" invisible="True"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="company_id" invisible="True"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="account_fiscal_sequence_tree" model="ir.ui.view">
        <field name="name">account.fiscal.sequence.tree</field>
        <field name="model">account.fiscal.sequence</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="fiscal_type_id"/>
                <field name="next_fiscal_number"/>
                <field name="sequence_start"/>
                <field name="sequence_end"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="account_fiscal_sequence_search" model="ir.ui.view">
        <field name="name">account.fiscal.sequence.search</field>
        <field name="model">account.fiscal.sequence</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="account_fiscal_sequence_action" model="ir.actions.act_window">
        <field name="name">Fiscal Sequences</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.fiscal.sequence</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="account_fiscal_sequence_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_create">
                No Fiscal Sequence found!
            </p>
            <p>
                You can create your first Fiscal Sequence here.
            </p>
        </field>
    </record>

    <record id="account_fiscal_type_form" model="ir.ui.view">
        <field name="name">account.fiscal.type.form</field>
        <field name="model">account.fiscal.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="prefix"/>
                            <field name="type"/>
                            <field name="journal_type" invisible="True"/>
                            <field name="padding">8</field>
                            <field name="assigned_sequence"/>
                            <field name="requires_document"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="journal_id" options="{'no_create': True}" domain="[('type', '=', journal_type), ('l10n_do_fiscal_journal', '=', True)]"/>
                            <field name="fiscal_position_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="account_fiscal_type_tree" model="ir.ui.view">
        <field name="name">account.fiscal.type.tree</field>
        <field name="model">account.fiscal.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="prefix"/>
                <field name="type"/>
            </list>
        </field>
    </record>

    <record id="account_fiscal_type_action" model="ir.actions.act_window">
        <field name="name">Fiscal Types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.fiscal.type</field>

        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="account_fiscal_sequence_menu_parent" name="Fiscal Dominican Republic" parent="account.menu_finance" sequence="90"/>

    <menuitem id="account_fiscal_sequence_menu" action="account_fiscal_sequence_action" parent="account_fiscal_sequence_menu_parent" name="Fiscal Sequences" />

    <menuitem id="account_fiscal_type_menu" action="account_fiscal_type_action" parent="account_fiscal_sequence_menu_parent" name="Fiscal Types" groups="base.group_no_one" />

</odoo>
