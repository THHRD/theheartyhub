<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Form View to Modify it -->
        <record id="ecf_product_template_form_view" model="ir.ui.view">
            <field name="name">ecf.product.template.form.view</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='general_information']" position="after">
                    <page name="ecf" string="Configuracion de ECF">
                        <group name="group_3" string="Datos de ECF">
                            <group>
                                <field name="ecf_default_code"/>
                                <field name="ecf_tipo_codigo"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
      </record>
      <record id="ecf_product_view_form" model="ir.ui.view">
            <field name="name">produc.product.ecf.form</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
              <xpath expr="//field[@name='additional_product_tag_ids']" position="after">
                  <field name="ecf_default_code"/>
                  <field name="ecf_tipo_codigo"/>
                </xpath>
            </field>
        </record>   
    </data>
</odoo>
