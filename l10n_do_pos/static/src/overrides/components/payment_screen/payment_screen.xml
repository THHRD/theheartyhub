<?xml version="1.0" encoding="UTF-8"?>
<templates id="template">
    <t t-name="l10n_do_pos.PaymentScreenFiscalButton" t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension" owl="1">
        <xpath expr="//button[hasclass('js_invoice')]" position="after">
            <button
                t-if="env.services.pos.config.l10n_do_fiscal_journal"
                class="control-button setFiscalType button btn btn-light btn-lg w-100 w-md-50 lh-lg text-truncate"
                t-att-class="currentOrder?.fiscal_type_id ? ' is-set' : ''"
                t-on-click="onClickSetFiscalType"
            >
                <i class="fa fa-edit me-2" role="img" aria-label="Set fiscal Type" title="Set fiscal Type"/>
                <span t-esc="currentFiscalTypeName"/>
            </button>
        </xpath>

        <xpath expr="//button[hasclass('js_invoice')]" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>
    </t>
</templates>
