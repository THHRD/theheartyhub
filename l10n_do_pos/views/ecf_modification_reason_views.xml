<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ecf_modification_reason_tree" model="ir.ui.view">
        <field name="name">ecf.modification.reason.list</field>
        <field name="model">ecf.modification.reason</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ecf_modification_reason_form" model="ir.ui.view">
        <field name="name">ecf.modification.reason.form</field>
        <field name="model">ecf.modification.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence" invisible="1"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ecf_modification_reason" model="ir.actions.act_window">
        <field name="name">Razones Nota de Crédito</field>
        <field name="res_model">ecf.modification.reason</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ecf_modification_reason"
              name="Razones Nota de Crédito"
              parent="point_of_sale.menu_point_config_product"
              action="action_ecf_modification_reason"
              sequence="95"/>
</odoo>