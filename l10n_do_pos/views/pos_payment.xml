<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_view_form" model="ir.ui.view">
        <field name="name">pos.payment.view.form</field>
        <field name="model">pos.payment</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_payment_form"/>
        <field name="arch" type="xml">


            <xpath expr="//field[@name='transaction_id']" position="after">
                <separator  string="Nóta de Crédito"></separator>
                <field name="credit_note_ncf" readonly="1"></field>
                <field name="credit_note_partner_id" readonly="1"></field>
                <field name="credit_note_source_order_id" readonly="1"></field>
                <field name="credit_note_ticket" readonly="1"></field>
            </xpath>

        </field>
    </record>
</odoo>
